# Stefano Icardi Website - Environment Variables
#
# Copy this file to .env.local and fill in the values

# ====================
# Email Configuration (Resend)
# ====================

# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# The email address that will appear as the sender
# For testing, use onboarding@resend.dev
# For production, configure a verified domain in Resend
RESEND_FROM_EMAIL=onboarding@resend.dev

# The email address that will receive contact form submissions
CONTACT_EMAIL=stefano.icardi@outlook.com

# ====================
# Site Configuration
# ====================

# Base URL of the website (used for SEO, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://stefanoicardi.com

# ====================
# Analytics (Optional)
# ====================

# Vercel Analytics (automatically enabled on Vercel deployment)
# No configuration required

# ====================
# Development Notes
# ====================

# The contact form will work in "development mode" without a Resend API key:
# - Form submissions will be logged to the console
# - No actual emails will be sent
#
# To test email sending:
# 1. Create a free Resend account at https://resend.com
# 2. Get your API key from the dashboard
# 3. Set RESEND_API_KEY in your .env.local file
